      "custom_registration_fields_hint": [
        {"field_name": "team_name", "display_label": "Team Name", "field_type": "text", "options": []},
        {"field_name": "problem_track", "display_label": "Preferred Problem Track", "field_type": "dropdown", "options": ["AI/ML", "Web/App", "IoT/Hardware", "Blockchain", "Open Innovation"]},
        {"field_name": "tshirt_size", "display_label": "T-Shirt Size", "field_type": "dropdown", "options": ["S", "M", "L", "XL", "XXL"]},
        {"field_name": "dietary_pref", "display_label": "Dietary Preference", "field_type": "dropdown", "options": ["Veg", "Non-Veg", "Vegan", "No preference"]}
