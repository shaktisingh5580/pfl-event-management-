      "default_schedule": [
        {"time": "09:00", "duration_mins": 60, "activity": "Registration & Kit Distribution", "location": "Main Hall", "coordinator": "TBD", "notes": ""},
        {"time": "10:00", "duration_mins": 30, "activity": "Opening Ceremony & Problem Statement Reveal", "location": "Auditorium", "coordinator": "TBD", "notes": ""},
        {"time": "10:30", "duration_mins": 780, "activity": "Hacking Phase Begins", "location": "Lab Rooms", "coordinator": "TBD", "notes": "Teams work on their projects"},
        {"time": "13:00", "duration_mins": 60, "activity": "Lunch", "location": "Canteen", "coordinator": "TBD", "notes": ""},
        {"time": "16:00", "duration_mins": 30, "activity": "Mentor Rounds", "location": "All Rooms", "coordinator": "TBD", "notes": ""},
        {"time": "22:30", "duration_mins": 30, "activity": "Submission Deadline & Freeze", "location": "Online", "coordinator": "TBD", "notes": "Push to GitHub/DevPost"},
        {"time": "09:00", "duration_mins": 120, "activity": "Judging & Presentations", "location": "Main Hall", "coordinator": "TBD", "notes": ""},
        {"time": "12:00", "duration_mins": 90, "activity": "Prize Distribution", "location": "Auditorium", "coordinator": "TBD", "notes": ""}
