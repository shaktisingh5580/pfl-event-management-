{
  "templates": [
    {
      "id": "techfest",
      "name": "TechFest / Technical Festival",
      "icon": "🎓",
      "description": "Multi-day college technical festival with hackathon, coding contests, paper presentations, and expo.",
      "event_type": "Technical Festival",
      "theme": "Technology & Innovation",
      "required_fields": [
        "College name and department organizing it",
        "Number of technical events (hackathon, coding, project expo, etc.)",
        "Total expected participants",
        "Venue halls and their capacities",
        "Prize pool budget in INR",
        "Event dates and duration (1 day / 2 days / 3 days)",
        "Sub-events list with max participants each",
        "Coordinators and faculty in-charges",
        "Registration fee (if any)",
        "Judgment panel details"
      ],
      "default_schedule": [
        {"time": "08:00", "duration_mins": 60, "activity": "Participant Registration & Check-In", "location": "Main Gate", "coordinator": "TBD", "notes": "Scan QR codes at entry"},
        {"time": "09:00", "duration_mins": 45, "activity": "Inauguration Ceremony", "location": "Main Auditorium", "coordinator": "TBD", "notes": "Chief guest, lamp lighting"},
        {"time": "10:00", "duration_mins": 180, "activity": "Hackathon Round 1", "location": "Lab Complex", "coordinator": "TBD", "notes": ""},
        {"time": "10:00", "duration_mins": 120, "activity": "Coding Contest", "location": "Computer Lab A", "coordinator": "TBD", "notes": ""},
        {"time": "13:00", "duration_mins": 60, "activity": "Lunch Break", "location": "Canteen", "coordinator": "TBD", "notes": "Food coupons distributed"},
        {"time": "14:00", "duration_mins": 180, "activity": "Hackathon Round 2 / Project Expo", "location": "Lab Complex & Hall B", "coordinator": "TBD", "notes": ""},
        {"time": "17:00", "duration_mins": 60, "activity": "Prize Distribution & Valedictory", "location": "Main Auditorium", "coordinator": "TBD", "notes": ""}
      ],
      "custom_registration_fields_hint": [
        {"field_name": "participating_events", "display_label": "Events Participating In", "field_type": "dropdown", "options": ["Hackathon", "Coding Contest", "Paper Presentation", "Project Expo", "Multiple"]},
        {"field_name": "team_name", "display_label": "Team Name", "field_type": "text", "options": []},
        {"field_name": "tshirt_size", "display_label": "T-Shirt Size", "field_type": "dropdown", "options": ["XS", "S", "M", "L", "XL", "XXL"]}
      ]
    },
    {
      "id": "hackathon",
