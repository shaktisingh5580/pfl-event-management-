# ═══════════════════════════════════════════════════════════
#  AI Event Management System — Environment Configuration
#  Copy this file to .env and fill in your values.
#  
# ═══════════════════════════════════════════════════════════

# ── LLM (OpenRouter — https://openrouter.ai/keys) ─────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
OPENROUTER_MODEL=
OPENROUTER_EMBEDDING_MODEL=

# ── Supabase (https://supabase.com) ───────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Telegram Bot (https://t.me/BotFather) ─────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID==
TELEGRAM_GROUP_CHAT_ID=-

# ── GitHub (https://github.com/settings/tokens) ───────────
GITHUB_TOKEN=
GITHUB_USERNAME=

# ── Vercel (https://vercel.com/account/tokens) ────────────
VERCEL_TOKEN
VERCEL_TEAM_ID=                        # Leave blank for personal accounts

# ── Cloudinary (https://cloudinary.com) ───────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Google APIs ───────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
GOOGLE_DRIVE_FOLDER_ID=   # Photo folder

# ── Buffer (https://buffer.com) ───────────────────────────
BUFFER_ACCESS_TOKEN=1/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BUFFER_INSTAGRAM_PROFILE_ID=
BUFFER_LINKEDIN_PROFILE_ID=

